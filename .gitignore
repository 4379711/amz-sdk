# ====== OS ======
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ====== IDE ======
.idea/
.vscode/
!.vscode/extensions.json
*.iml
*.iws
*.swp
*.bak
*.tmp
*~

# ====== Go ======
# Compiled binaries / archives
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.out
coverage.html

# Vendor directory (not used; modules are the source of truth)
vendor/

# Go workspace files
go.work
go.work.sum

# Build output
bin/
build/
dist/
out/

# ====== Logs ======
*.log
logs/

# ====== Env files (no secrets in source control) ======
.env
.env.*
!.env.example
!.env.*.example

# ====== 本地集成测试目录 ======
# test/ 下是开发者本地用的集成测试与凭据,含真实 LwA ClientID / ClientSecret /
# refresh_token,以及测试运行产生的大体积产物(如 tree_us.xml ~50 MB)。
# 整个目录不入库,使用方式见主 README 的 Quick start。
test/
